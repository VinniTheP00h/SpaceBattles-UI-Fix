/* ==UserStyle==
@name           SpaceBattles Old Design minor fixes
@namespace      https://github.com/VinniTheP00h/SpaceBattles-UI-Fix
@version        1.0.0
@description    Fixes a number of minor issues on SB's new recreated old theme
@author         VinniTheP00h
@license MIT
==/UserStyle== */
@-moz-document url-prefix("https://forums.spacebattles.com/") {
    .button.button--link,
    a.button.button--link {
        background: #60646f;
        color: white;
    }

    .button.button--link:hover,
    a.button.button--link:hover {
        background-color: #737885;
    }
}
